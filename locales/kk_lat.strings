"tour_section_1_title_1" = "Neden bastasam boladı?";
"tour_section_1_text_1" = "Jeke beyin acıw — bul sayttağı alğacqı äri eń mańızdı qadam.";
"tour_section_1_text_2" = "Tirkeliw ücin atıńızdı, elektrondıq poctańızdı engizip, qupıyasöz oylap tapsańız jetkilikti.";
"tour_section_1_text_3" = "<b>Esińizde bolsın:</b> Poctańız saytqa kiriw ücin logıyn retinde qoldanıladı. Tegińizdi engiziw mindetti emes. Qupıyasözdi umıtıp qalsańız, onı <a href='/restore'>qalpına keltire alasız</a>.";
"tour_section_1_bottom_text_1" = "Tirkeliw arqılı siz <a href='/terms'>paydalanıw erejeleri</a> jäne <a href='/privacy'>qupıyalılıq sayasatımen</a> kelisesiz.";

"tour_section_2_title_1" = "Jeke paraqcańız";
"tour_section_2_text_1_1" = "Tirkelgen soń jüye sizdi avtomattı türde <b>jeke</b> paraqcańızğa bağıttaydı.";
"tour_section_2_text_1_2" = "Onı kez kelgen waqıtta öz qalawıńızca öńdey alasız.";
"tour_section_2_text_1_3" = "<b>Keńes:</b> Paraqcańız tartımdı köriniwi ücin qızığıwlıqtarıńız tuwralı jazıp, icki düniyeńizdi sıypattaytın süwret jüktep qoyıńız.";
"tour_section_2_bottom_text_1" = "Dostarıńız siz tuwralı qanday aqparattı köre alatının tek özińiz cecesiz.";
"tour_section_2_title_2" = "Qupıyalılıqtı rettew";
"tour_section_2_text_2_1" = "Jeke derekterińizdi kim köre alatının jäne sizge kim jaza alatının özińiz baptay alasız.";
"tour_section_2_text_2_2" = "Paraqcańızdı izdew jüyelerinen nemese tirkelmegen paydalanıwcılardan jasırıp qoyıwğa boladı.";
"tour_section_2_text_2_3" = "<b>Eskertiw:</b> Bolacaqta qupıyalılıq baptawları äli de jetildiriledi.";
"tour_section_2_title_3" = "Paraqcanıń qısqa mekenjayı";
"tour_section_2_text_3_1" = "Tirkelgen kezde sizge <b>@id12345</b> türindegi biregey nömir beriledi.";
"tour_section_2_text_3_2" = "Bastapqıda berilgen bul <b>standarttı ID-di</b> <b>özgertiw mümkin emes</b>.";
"tour_section_2_text_3_3" = "Alayda paraqca baptawlarında özińizge unaytın jeke mekenjaydı qosa alasız. Onı kez kelgen waqıtta <b>özgertiwge boladı</b>.";
"tour_section_2_text_3_4" = "<b>Keńes:</b> Kem degende 5 tańbadan turatın bos mekenjaydı tańdańız. Özińizge erekce silteme alıp alıńız :)";
"tour_section_2_bottom_text_2" = "<i>Latın äripterinen turatın qısqa silteme ornatıwğa boladı. Sonday-aq sandardı, nükteler men astın sızıw tańbaların qoldanıwğa ruqsat (basında ne sońında bolmasa).</i>";
"tour_section_2_title_4" = "Qabırğa";

"tour_section_3_title_1" = "Esteliktermen bölisińiz";
"tour_section_3_text_1" = "«Süwretter» bölimi arqılı dostarıńızğa öz ömirińizdi körsete alasız.";
"tour_section_3_text_2" = "Albomdarıńızdı jasap, basqalardıń süwretterin tamacalańız.";
"tour_section_3_text_3" = "Albomdardı kim köre alatının qupıyalılıq böliminde retteńiz.";
"tour_section_3_bottom_text_1" = "Sayahattar, merekeler nemese jay ğana qızıqtı sätter ücin ceksiz mölcerde albom jasawğa boladı.";

"tour_section_4_title_1" = "İzdew jüyesi";
"tour_section_4_text_1" = "«İzdew» bölimi arqılı dostarıńızdı nemese qızıqtı toptardı taba alasız.";
"tour_section_4_text_2" = "Bul bölim waqıt öte kele jańa füwnksiyalarmen tolığıp otıradı.";
"tour_section_4_text_3" = "Paydalanıwcılardı atı-jöni boyınca, al qawımdastıqtardı atawı boyınca izdeńiz.";
"tour_section_4_title_2" = "Jıldam izdew";
"tour_section_4_text_4" = "Waqıt ünemdew ücin sayttıń joğarğı jağındağı izdew jolağın qoldanıńız.";

"tour_section_5_title_1" = "Beyne jükteńiz";
"tour_section_5_text_1" = "Saytqa beyne men kliypterdi cektewsiz jüktey alasız.";
"tour_section_5_text_2" = "Beynelerdi kim tamacalay alatının özińiz belgileńiz.";
"tour_section_5_bottom_text_1" = "Beyneni arnayı bölimge ötpey-aq, tikeley qabırğadağı jazbağa tirkey salıwğa boladı:";
"tour_section_5_title_2" = "YouTube-ten importtaw";
"tour_section_5_text_3" = "Fayldı tikeley jüktewden bölek, YouTube-tegi beynelerdi silteme arqılı qosıwğa boladı.";

"tour_section_6_title_1" = "Muzıka tıńdańız";
"tour_section_6_text_1" = "«Änderim» böliminde süyikti änderińizdi tıńday alasız.";
"tour_section_6_text_2" = "Bul bölimniń de qoljetimdiligi qupıyalılıq baptawlarında retteledi.";
"tour_section_6_text_3" = "Eń tanımal änder «Tanımal» böliminde, al sońğı jüktelgender — «Jańa» qoyındısında.";
"tour_section_6_text_4" = "Ändi öz tizimińizge qosıw ücin plyüws belgisin basıńız nemese izdewdi qoldanıńız.";
"tour_section_6_text_5" = "Qajetti ändi taba almasańız, onı özińiz jüktey alasız.";
"tour_section_6_bottom_text_1" = "<b>Mańızdı:</b> Audiofayldar avtorlıq quqıqtı buzbawı tiyis.";
"tour_section_6_title_2" = "Äntizim jasańız";
"tour_section_6_text_6" = "«Äntizimder» böliminde änderdi talğamıńızğa qaray toptastıra alasız.";
"tour_section_6_text_7" = "Basqa paydalanıwcılardıń äntizimderin de öz jıynağıńızğa qosıwğa boladı.";

"tour_section_7_title_1" = "Jańalıqtar taspası";
"tour_section_7_text_1" = "«Jańalıqtar» bölimi ekige bölinedi: jergilikti jäne jahandıq taspa.";
"tour_section_7_text_2" = "Jergilikti taspada tek dostarıńız ben jazılğan toptarıńızdıń jazbaları körsetiledi.";
"tour_section_7_bottom_text_1" = "Bizde jasandı usınıstar jüyesi joq. <b>Taspańızdı tek özińiz qalıptastırasız</b>.";

"tour_section_8_title_1" = "Sayt tınısı";
"tour_section_8_text_1" = "Jahandıq taspada sayttağı barlıq paydalanıwcılar men toptardıń acıq jazbaları jıynaqtalğan.";
"tour_section_8_text_2" = "Bul bölimde mazmun öte köp äri ärtürli, sondıqtan bärine birdey unamawı mümkin.";
"tour_section_8_bottom_text_1" = "Jahandıq taspanıń sırtqı türi negizgi jańalıqtar taspasımen birdey.";
"tour_section_8_bottom_text_2" = "Munda süwretterden bastap, sawalnamalar men jasırın jazbalarğa deyin bärin tabıwğa boladı.";

"tour_section_9_title_1" = "Qawımdastıq qurıńız";
"tour_section_9_text_1" = "Saytta mıńdağan qızıqtı toptar men qawımdastıqtar bar.";
"tour_section_9_text_2" = "Özińizge unaytın toptarğa qosılıńız, bolmasa öz qawımdastığıńızdı qurıńız.";
"tour_section_9_text_3" = "Är topta wiykiy-better, fotoalbomdar, talqılawlar men paydalı siltemeler blogı bar.";
"tour_section_9_title_2" = "Birlese basqarıw";
"tour_section_9_text_2_1" = "Toptı avatar astındağı «Basqarıw» mäziri arqılı basqara alasız.";
"tour_section_9_text_2_2" = "Senimdi dostarıńızdı äkimci retinde tağayındańız.";
"tour_section_9_text_2_3" = "Qajet bolsa, äkimciler tizimin jasırıp qoyıwğa da boladı.";
"tour_section_9_bottom_text_1" = "«Toptar» bölimin sol jaq mäzirden taba alasız.";
"tour_section_9_bottom_text_2" = "Top ülgisi";
"tour_section_9_bottom_text_3" = "Toptar — bul awdıytorıyamen baylanıs ornatqısı keletin uyım men qawımdastıqtar ücin taptırmas qural.";

"tour_section_10_title_1" = "Oybay!";
"tour_section_10_text_1" = "Bul bölim tuwralı aytıp bereyin dep edik, ol äli dayın emes eken. Attap ötip, äri qaray jalğastıra bersek qaytedi?";

"tour_section_11_title_1" = "Stiyl jäne dizayn";
"tour_section_11_text_1" = "Tirkelgen kezde paraqcańızğa standarttı stiyl ornatıladı.";
"tour_section_11_text_2" = "Eger bul stiyl sizge tım eski bolıp körinse, onı özgertiwge mümkindik bar.";
"tour_section_11_text_3" = "<b>Wayımdamańız:</b> <a href='https://docs.ovk.to/'>qujattamanı</a> oqıp, öz dizaynıńızdı jasańız, bolmasa katalogtan dayın keyipti tańdasańız boladı.";
"tour_section_11_bottom_text_1" = "Katalogtı «Baptaw» — «İnterfeys» böliminen taba alasız.";
"tour_section_11_wordart" = "<img src='/assets/packages/static/openvk/img/tour/wordart_en.png' width='65%'>";

"tour_section_12_title_1" = "Fondıq süwretter";
"tour_section_12_text_1" = "Paraqcanıń artına eki süwret qoyıwğa boladı.";
"tour_section_12_text_2" = "Olar oń jäne sol jaqta körinedi.";
"tour_section_12_text_3" = "<b>Keńes:</b> Süwrettiń ornalasıwımen täjiriybe jasap körińiz — gradiyentter nemese ädemi panoramalar keremet körinedi.";
"tour_section_12_title_2" = "Avatarlar";
"tour_section_12_text_2_1" = "Avatar stiylin tańdawğa boladı: standarttı, döńgelek nemese carcı (1:1).";
"tour_section_12_text_2_2" = "Bul baptawlar tek sizge ğana körinedi.";
"tour_section_12_title_3" = "Mäzirdi baptaw";
"tour_section_12_text_3_1" = "Özińiz qoldanbaytın bölimderdi sol jaq mäzirden alıp tastay alasız.";
"tour_section_12_text_3_2" = "<b>Esińizde bolsın:</b> Paraqca, Dostar, Hattar sıyaqtı negizgi bölimderdi jasırıw mümkin emes.";
"tour_section_12_title_4" = "Jazbalardıń körinisi";
"tour_section_12_text_4_1" = "Eski qabırğa dizaynınan jalıqsańız, onı «Mikroblog» türine awıstırıp körińiz.";
"tour_section_12_text_4_2" = "Dizayn türin qalağan waqıtıńızda awıstıra alasız.";
"tour_section_12_text_4_3" = "<b>Eskertiw:</b> Eski köriniste sońğı pikirler taspada birden jüktelmewi mümkin.";
"tour_section_12_bottom_text_1" = "Fon baptaw beti";
"tour_section_12_bottom_text_2" = "Fondıq süwreti bar paraqcalardıń ülgisi";
"tour_section_12_bottom_text_3" = "Osı füwnksiya arqılı paraqcańızğa erekce stiyl berińiz.";
"tour_section_12_bottom_text_4" = "Eski qabırğa";
"tour_section_12_bottom_text_5" = "Mikroblog";

"tour_section_13_title_1" = "Promokodtar";
"tour_section_13_text_1" = "Saytta promokodtar arqılı reytiyngińizdi köteriwge de, dawıstar alıwğa da boladı.";
"tour_section_13_text_2" = "Munday küwpondar merekelerde nemese mańızdı oqıyğalarda beriledi. Jańalıqtardı jiberip almas ücin <a href='https://t.me/openvk'>Telegram-arnamızğa</a> jazılıńız.";
"tour_section_13_text_3" = "Kodtı engizgen soń, dawıstar avtomattı türde cotıńızğa tüsedi.";
"tour_section_13_text_4" = "<b>Esińizde bolsın:</b> Promokodtardıń qoldanılıw merzimi cektewli.";
"tour_section_13_bottom_text_1" = "Promokodtar ädette 24 tańbadan turadı.";
"tour_section_13_bottom_text_2" = "Mısalı, sätti qoldanılğan kod sizge 100 dawıs sıylawı mümkin.";
"tour_section_13_bottom_text_3" = "<b>Nazar awdarıńız:</b> Är promokodtı bir paydalanıwcı tek bir ret qoldana aladı.";

"tour_section_14_title_1" = "Telefon men gadjetterge";
"tour_section_14_text_1" = "Qazirgi waqıtta sayttıń mobıyldi veb-nusqası joq, biraq Android-qa arnalğan qoldanba bar.";
"tour_section_14_text_2" = "OpenVK Legacy — 2013 jılğı äwelgi dizaynğa negizdelgen, eski qurılğılarğa arnalğan qoldanba.";
"tour_section_14_text_3" = "Qoldanba Android 2.1 Eclair nusqasınan bastap jumıs istey beredi, sondıqtan onı tipti ep-eski smartfondarğa da ornatıwğa boladı.";

"tour_section_14_title_2" = "Qaydan jüktesem boladı?";
"tour_section_14_text_2_1" = "Qoldanbanıń resmiy nusqaların F-Droid repoziytoriyinen taba alasız.";
"tour_section_14_text_2_2" = "Beta-testerler ücin jańartıwlar bölek arnada cığadı.";
"tour_section_14_text_2_3" = "<b>Eskertiw:</b> Qoldanbada qateler bolıwı mümkin. Mäsele tuwındasa, onı <a href='/app'>resmiy topqa</a> habarlańız.";

"tour_section_14_bottom_text_1" = "Skrincottar";
"tour_section_14_bottom_text_2" = "Osımen saytqa colıw ayatqaldı. Eger mobıyldi qoldanbanı ornatıw, öz tobıńızdı qurıw ne dostardı caqırıw sıyaqtı mümkindikter qızıqtırsa, <a href='/reg'>tirkelip</a>, birden bastap ketseńiz boladı!";
"tour_section_14_bottom_text_3" = "Osımen saytqa colıw ayaqtaldı. Qoc keldińiz!";
